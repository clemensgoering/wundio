# Wundio - Git Attributes

# Force LF line endings everywhere
* text=auto eol=lf

# Shell scripts – force executable bit in index
scripts/*.sh text eol=lf diff
diagnose/*.sh text eol=lf diff

# Python files
*.py text eol=lf

# Web files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf

# Markdown
*.md text eol=lf

# Build output – never track
core/static/ export-ignore
web/package-lock.json export-ignore