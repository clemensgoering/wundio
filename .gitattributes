# Wundio - Git Attributes

# Force LF line endings for shell scripts (avoid CRLF issues)
*.sh text eol=lf

# Python files
*.py text eol=lf

# Web files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf

# Markdown
*.md text eol=lf

# Keep executable bit in repo for scripts
scripts/*.sh -diff